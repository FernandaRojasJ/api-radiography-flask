DATABASE_URL=sqlite:///./xray_database.db
SECRET_KEY=super_secret_key_for_jwt
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=xray_records
CLOUDINARY_UPLOAD_TYPE=authenticated
CLOUDINARY_SIGNED_URL_TTL_SECONDS=600
JWT_ALGORITHM=HS256
CLOUDINARY_MIN_SIGNED_URL_TTL_SECONDS=60
CLOUDINARY_MAX_SIGNED_URL_TTL_SECONDS=600
SECURE_IMAGE_TOKEN_TTL_SECONDS=600
IMAGE_PRIVACY_SCHEDULER_ENABLED=true
MAX_FILE_SIZE_MB=5
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile
GOOGLE_OAUTH_TIMEOUT_SECONDS=10